{
  "name": "obsidian-enhanced-pomodoro-timer",
  "version": "2.0.0",
  "description": "A beautiful Pomodoro timer with session logging, statistics, and notifications for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "obsidian",
    "pomodoro",
    "timer",
    "productivity",
    "focus",
    "time-tracking"
  ],
  "author": "oroku saki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orokusaki/obsidian-pomodoro-timer"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.19.11",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "obsidian": "latest",
    "ts-jest": "^29.1.1",
    "tslib": "2.6.2",
    "typescript": "5.3.3"
  }
}
